AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=southeastasia

# Gemini TTS (Google AI Studio) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

PORT=3001
MAX_FILE_SIZE_MB=500

# Comma-separated list of allowed CORS origins (default: http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173

# Job store TTL: how long completed/failed jobs are kept in memory (ms, default: 2 hours)
JOB_TTL_MS=7200000

# How often the job cleanup runs (ms, default: 15 minutes)
JOB_CLEANUP_INTERVAL_MS=900000

# Google Cloud Speech-to-Text v2 + Chirp (optional: required only for provider=google)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_STORAGE_BUCKET=your-gcs-bucket-name

# Speech-to-Text V2 Configuration
# STT_LOCATION: STT API/recognizer location (e.g. asia-southeast1 or global)
STT_LOCATION=asia-southeast1
# STT_RECOGNIZER: name of a pre-created recognizer, or '_' to use the auto recognizer
STT_RECOGNIZER=chirp-thai-recognizer
STT_MODEL=chirp_2
